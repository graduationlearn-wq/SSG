<%
  // ── SAFE LOCALS (Round F — InsurTech SaaS / B2B API Platform) ──
  const L = locals || {};
  const esc = (s) => (s == null ? '' : String(s));
  const def = (v, d) => (v && String(v).trim() ? v : d);
  const bn      = esc(L.businessName) || 'Stratus';
  const tagln   = esc(L.tagline)      || 'Insurance APIs for the modern stack.';
  const accent  = L.primaryColor      || '#00a085';
  const year    = L.year              || new Date().getFullYear();

  // Hero
  const heroBadgeV         = def(L.heroBadge,         'SOC 2 Type II · IRDAI-aligned');
  const heroHeadlineLeadV  = def(L.heroHeadlineLead,  'Insurance APIs for the');
  const heroHeadlineAccentV= def(L.heroHeadlineAccent,'modern stack.');
  const heroSubV           = def(L.heroSub,           'Quote, underwrite, and settle claims with one developer-first platform. Used by 80+ insurers and brokers across India to ship products in days, not quarters.');
  const heroCtaPrimaryV    = def(L.heroCtaPrimary,    'Get API Keys');
  const heroCtaSecondaryV  = def(L.heroCtaSecondary,  'Read Docs');
  const codeLanguageV      = def(L.codeLanguage,      'node.js');
  const codeSnippetV       = def(L.codeSnippet,
`const stratus = new Stratus(process.env.STRATUS_KEY);

const quote = await stratus.quotes.create({
  product: 'health',
  age: 32,
  city: 'mumbai',
  cover: 1000000
});

console.log(quote.premium);
// → 8420 (₹/year, GST inclusive)`);

  // Customer logos
  const customerLogosList = (Array.isArray(L.customerLogos) && L.customerLogos.length)
    ? L.customerLogos.map(c => esc(c.name || c)).filter(Boolean)
    : ['Acko', 'Digit', 'Bajaj Allianz', 'Star Health', 'HDFC Ergo', 'Tata AIG', 'Care Health', 'PolicyBazaar'];

  // Products
  const productsLabelV    = def(L.productsLabel,    'API Suite');
  const productsHeadlineV = def(L.productsHeadline, 'One stack. Every insurance primitive.');
  const productsBodyV     = def(L.productsBody,     'A coherent set of APIs designed by engineers who shipped insurance infrastructure at scale. Pick what you need, ignore the rest.');
  const productsList = (Array.isArray(L.products) && L.products.length && (L.products[0].name || L.products[0].title))
    ? L.products
    : [
        { icon:'⚡', name:'Quotes API',        body:'Sub-100ms quotes across 30+ insurers. Smart caching, fallback handling, and full normalisation across products.', endpoint:'POST /v1/quotes' },
        { icon:'🛡', name:'Underwriting API',  body:'Risk scoring with explainable signals. Returns approve / refer / decline plus the precise reasons regulators ask for.', endpoint:'POST /v1/underwrite' },
        { icon:'📋', name:'Claims API',         body:'File, track, and settle claims through one endpoint. Document OCR, auto-fraud scoring, and SLA dashboards built in.',   endpoint:'POST /v1/claims' },
        { icon:'🔐', name:'KYC & AML',           body:'Aadhaar, PAN, video KYC, sanctions screening — all bundled with audit trails ready for IRDAI inspections.',         endpoint:'POST /v1/kyc' },
        { icon:'📊', name:'Analytics API',       body:'Customer cohort, claims-ratio, and product-mix dashboards delivered as JSON. Plug straight into your BI stack.',     endpoint:'GET  /v1/analytics' },
        { icon:'🔔', name:'Webhooks',           body:'Reliable, signed, idempotent event delivery. Every quote, policy, and claim triggers events with retries and DLQs.',   endpoint:'POST /v1/webhooks' }
      ];

  // How it works
  const howLabelV    = def(L.howLabel,    'Integration');
  const howHeadlineV = def(L.howHeadline, 'Live in days, not quarters.');
  const howStepsList = (Array.isArray(L.howSteps) && L.howSteps.length)
    ? L.howSteps
    : [
        { title:'Sign up',        body:'Create a sandbox account. No credit card required, no sales call to start.',                              duration:'5 minutes' },
        { title:'Get API keys',   body:'Generate sandbox + production keys in the dashboard. Rotate, scope, and revoke any time.',                duration:'Instant' },
        { title:'Build & test',   body:'Code against the sandbox with realistic mock data. Full request logs, replay, and time-travel debugging.', duration:'1–3 days' },
        { title:'Ship to prod',   body:'Flip the keys, deploy. We monitor with you for the first 30 days through a shared Slack channel.',         duration:'Same day' }
      ];

  // Stats
  const platformStatsList = (Array.isArray(L.platformStats) && L.platformStats.length)
    ? L.platformStats
    : [
        { value:'99.99', suffix:'%',   label:'Uptime SLA · 12 months' },
        { value:'80',    suffix:'+',   label:'Insurers integrated' },
        { value:'2.4',   suffix:'B+',  label:'Annual API calls' },
        { value:'<80',   suffix:'ms',  label:'Median quote latency' }
      ];

  // Compliance
  const complianceLabelV    = def(L.complianceLabel,    'Compliance & Security');
  const complianceHeadlineV = def(L.complianceHeadline, 'Built for regulated workloads.');
  const complianceBodyV     = def(L.complianceBody,     'Every layer of the platform is built to satisfy regulatory and security audits — IRDAI inspections, RBI scrutiny, IT-Act and DPDP compliance, and the security reviews your customers will run on you.');
  const complianceBadgesList = (Array.isArray(L.complianceBadges) && L.complianceBadges.length)
    ? L.complianceBadges.map(b => esc(b.label || b)).filter(Boolean)
    : ['SOC 2 Type II', 'ISO 27001', 'IRDAI Aligned', 'DPDP Compliant', 'IT-Act Compliant', 'PCI-DSS Level 1', 'CKYCR Linked', 'AES-256 at rest'];

  // Pricing
  const pricingLabelV    = def(L.pricingLabel,    'Pricing');
  const pricingHeadlineV = def(L.pricingHeadline, 'Transparent, scaling pricing.');
  const pricingPlansList = (Array.isArray(L.pricingPlans) && L.pricingPlans.length)
    ? L.pricingPlans
    : [
        { name:'Starter',    price:'Free',          tagline:'For exploring the API',          popular:'No',  cta:'Start building',   features:'1,000 sandbox calls / month\nCommunity support\n3 webhook endpoints\nBasic dashboards' },
        { name:'Growth',     price:'₹49,000 / mo',  tagline:'For shipping products',           popular:'Yes', cta:'Talk to sales',    features:'500K production calls / month\n24-hour priority support\nUnlimited webhooks\nAdvanced analytics\n99.9% SLA' },
        { name:'Enterprise', price:'Custom',        tagline:'For regulated incumbents',        popular:'No',  cta:'Contact sales',    features:'Custom volume & rate limits\nDedicated CSM + Slack channel\nVPC peering & private link\nCustom SLAs up to 99.99%\nOn-prem deployment available' }
      ];

  // CTA
  const ctaHeadlineLeadV   = def(L.ctaHeadlineLead,   'Ready to integrate');
  const ctaHeadlineAccentV = def(L.ctaHeadlineAccent, 'in 24 hours?');
  const ctaBodyV           = def(L.ctaBody,           'Sandbox keys, full docs, and a Slack channel with our engineers — that\'s how integrations move from "let me explore" to "shipped" in a week.');
  const ctaButtonV         = def(L.ctaButton,         'Get API Keys');
  const ctaNoteV           = def(L.ctaNote,           'Sandbox keys are free · No credit card required');

  // Helpers
  function initialsOf(name) {
    if (!name) return '·';
    const parts = String(name).trim().split(/\s+/);
    const a = (parts[0] || '')[0] || '';
    const b = (parts[1] || '')[0] || (parts[0] || '').slice(1,2);
    return (a + b).toUpperCase();
  }
  function parseFeatures(raw) {
    return String(raw || '').split(/\r?\n/).map(s => s.trim()).filter(Boolean);
  }
  const emailV   = esc(L.email)   || 'partners@stratus.dev';
  const phoneV   = esc(L.phone)   || '+91 80 4567 8900';
  const addressV = esc(L.address) || 'Indiranagar, Bangalore 560038';
  const hoursV   = esc(L.hours)   || 'Mon–Fri · 09:00–18:00 IST';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= bn %> — <%= tagln %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:        #ffffff;
      --bg-2:      #f6f8fa;       /* subtle off-white for section separators */
      --bg-3:      #eef2f6;
      --surface:   #ffffff;
      --ink:       #0a0e14;
      --ink-soft:  rgba(10,14,20,.72);
      --ink-mute:  rgba(10,14,20,.5);
      --line:      rgba(10,14,20,.08);
      --line-md:   rgba(10,14,20,.16);
      --cyan:      <%= accent %>;
      --cyan-glow: rgba(0,160,133,.18);
      --gold:      #d97706;
      --purple:    #7c3aed;
      --pink:      #db2777;
      --green:     #059669;
      --red:       #dc2626;
      /* Dark sections use these (code panel, CTA band, footer) */
      --dark-bg:   #0a0e14;
      --dark-surface: #131923;
      --dark-line: rgba(255,255,255,.1);
      --dark-ink:  #e8edf5;
      --dark-ink-soft: rgba(232,237,245,.7);
      --dark-ink-mute: rgba(232,237,245,.45);
      --serif:     'Inter', system-ui, sans-serif;
      --mono:      'JetBrains Mono', ui-monospace, monospace;
    }
    html{scroll-behavior:smooth}
    body{font-family:var(--serif);background:var(--bg);color:var(--ink);line-height:1.65;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    button{font-family:inherit;cursor:pointer;border:none}
    .container{max-width:1240px;margin:0 auto;padding:0 32px}
    .reveal{opacity:0;transform:translateY(20px);transition:opacity .7s ease,transform .7s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    /* ── NAV */
    .nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.88);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:18px 0}
    .brand{display:flex;align-items:center;gap:10px;font-size:1.15rem;font-weight:700;letter-spacing:-.005em}
    .brand-dot{width:10px;height:10px;border-radius:50%;background:var(--cyan);box-shadow:0 0 14px var(--cyan-glow)}
    .nav-links{display:flex;gap:30px;list-style:none;align-items:center}
    .nav-links a{font-size:.9rem;color:var(--ink-soft);transition:color .2s;font-weight:500}
    .nav-links a:hover{color:var(--ink)}
    .nav-links .nav-cta{
      background:var(--ink);color:#ffffff;padding:8px 18px;border-radius:8px;
      font-weight:600;transition:background .2s
    }
    .nav-links .nav-cta:hover{background:#1f2937;color:#fff}

    /* ── HERO */
    .hero{padding:88px 0 110px;position:relative;overflow:hidden;background:linear-gradient(180deg,#ffffff 0%,var(--bg-2) 100%)}
    .hero::before{
      content:'';position:absolute;top:-200px;right:-150px;width:560px;height:560px;border-radius:50%;
      background:radial-gradient(circle,rgba(0,160,133,.08) 0%,transparent 70%);pointer-events:none
    }
    .hero::after{
      content:'';position:absolute;bottom:-160px;left:-200px;width:480px;height:480px;border-radius:50%;
      background:radial-gradient(circle,rgba(124,58,237,.05) 0%,transparent 70%);pointer-events:none
    }
    .hero-grid{display:grid;grid-template-columns:1.05fr 1fr;gap:56px;align-items:center;position:relative}
    .hero-badge{
      display:inline-flex;align-items:center;gap:8px;font-size:.78rem;font-weight:600;
      letter-spacing:.05em;color:var(--cyan);
      background:rgba(0,160,133,.08);border:1px solid rgba(0,160,133,.24);
      padding:7px 14px;border-radius:100px;margin-bottom:28px
    }
    .hero-badge::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--cyan);box-shadow:0 0 8px var(--cyan-glow)}
    .hero-title{
      font-size:clamp(2.4rem,5vw,4.6rem);font-weight:700;line-height:1.05;
      letter-spacing:-.025em;color:var(--ink);margin-bottom:24px
    }
    .hero-title .accent{color:var(--cyan)}
    .hero-sub{font-size:1.08rem;color:var(--ink-soft);max-width:540px;margin-bottom:36px;line-height:1.75;font-weight:400}
    .hero-actions{display:flex;gap:14px;flex-wrap:wrap}
    .btn{
      display:inline-flex;align-items:center;gap:8px;
      padding:13px 26px;border-radius:8px;
      font-size:.93rem;font-weight:600;letter-spacing:.005em;
      transition:transform .15s,background .2s,box-shadow .2s,color .2s
    }
    .btn:hover{transform:translateY(-1px)}
    .btn-primary{background:var(--ink);color:#ffffff;box-shadow:0 6px 22px rgba(10,14,20,.18)}
    .btn-primary:hover{background:#1f2937;color:#fff;box-shadow:0 12px 32px rgba(10,14,20,.28)}
    .btn-ghost{background:transparent;color:var(--ink);border:1px solid var(--line-md)}
    .btn-ghost:hover{background:var(--bg-2);border-color:var(--ink-mute)}

    /* Code panel — STAYS DARK against light page (Stripe pattern). */
    .code-panel{
      background:var(--dark-surface);border:1px solid var(--dark-line);border-radius:14px;
      overflow:hidden;font-family:var(--mono);font-size:.86rem;color:var(--dark-ink);
      box-shadow:0 30px 80px -28px rgba(10,14,20,.25), 0 0 0 1px rgba(0,160,133,.1);
      position:relative
    }
    .code-panel::before{
      content:'';position:absolute;top:-1px;left:24px;right:24px;height:2px;
      background:linear-gradient(90deg,var(--cyan),transparent);border-radius:0 0 4px 4px
    }
    .code-head{
      display:flex;align-items:center;gap:8px;padding:10px 14px;
      background:rgba(0,0,0,.25);border-bottom:1px solid var(--dark-line)
    }
    .code-dot{width:10px;height:10px;border-radius:50%}
    .code-dot.r{background:#f87171} .code-dot.o{background:#fbbf24} .code-dot.g{background:#34d399}
    .code-lang{margin-left:auto;font-size:.74rem;color:var(--dark-ink-mute);letter-spacing:.04em}
    .code-body{padding:22px 24px;overflow-x:auto;white-space:pre;color:#a3d4cc;line-height:1.6}
    .code-body .kw {color:var(--purple)}
    .code-body .fn {color:var(--cyan)}
    .code-body .str{color:var(--gold)}
    .code-body .num{color:var(--pink)}
    .code-body .cm {color:var(--ink-mute);font-style:italic}
    .code-body .var{color:var(--ink)}

    /* ── LOGOS STRIP */
    .logos{padding:32px 0;background:var(--bg);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
    .logos-eyebrow{
      text-align:center;font-size:.74rem;color:var(--ink-mute);letter-spacing:.16em;
      text-transform:uppercase;margin-bottom:20px;font-weight:500
    }
    .logos-row{
      display:flex;flex-wrap:wrap;justify-content:center;gap:22px 44px;
      max-width:1100px;margin:0 auto
    }
    .logo-name{font-size:1rem;font-weight:600;color:var(--ink-soft);letter-spacing:-.01em}

    /* ── SECTION HEAD */
    .section-pad{padding:96px 0}
    .section-head{text-align:center;max-width:760px;margin:0 auto 56px}
    .section-head.left{text-align:left;margin:0 0 56px}
    .section-eyebrow{
      font-size:.76rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;
      color:var(--cyan);margin-bottom:14px;display:inline-block
    }
    .section-title{
      font-size:clamp(2rem,3.6vw,3.2rem);font-weight:700;line-height:1.1;
      letter-spacing:-.02em;color:var(--ink);margin-bottom:14px
    }
    .section-title .accent{color:var(--cyan)}
    .section-body{font-size:1rem;color:var(--ink-soft);line-height:1.75;max-width:640px;margin:0 auto}
    .section-head.left .section-body{margin-left:0}

    /* ── PRODUCTS */
    .products{background:var(--bg)}
    .products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:18px}
    .product-card{
      background:var(--surface);border:1px solid var(--line);border-radius:14px;
      padding:28px;transition:transform .2s,border-color .2s,box-shadow .2s;
      display:flex;flex-direction:column
    }
    .product-card:hover{
      transform:translateY(-3px);border-color:rgba(0,160,133,.4);
      box-shadow:0 22px 50px -22px rgba(0,160,133,.18)
    }
    .product-icon{
      width:44px;height:44px;border-radius:10px;
      background:rgba(0,160,133,.08);color:var(--cyan);
      display:flex;align-items:center;justify-content:center;font-size:1.3rem;
      margin-bottom:18px;border:1px solid rgba(0,160,133,.18)
    }
    .product-name{font-size:1.18rem;font-weight:700;color:var(--ink);margin-bottom:8px;letter-spacing:-.005em}
    .product-body{font-size:.92rem;color:var(--ink-soft);line-height:1.7;margin-bottom:18px;flex:1}
    .product-endpoint{
      font-family:var(--mono);font-size:.78rem;color:var(--cyan);
      background:rgba(0,160,133,.06);border:1px solid rgba(0,160,133,.18);
      padding:6px 11px;border-radius:6px;display:inline-block;font-weight:500
    }

    /* ── HOW IT WORKS */
    .how{background:var(--bg-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
    .how-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;position:relative}
    .how-step{
      background:var(--surface);border:1px solid var(--line);border-radius:14px;
      padding:28px 24px;position:relative;box-shadow:0 1px 3px rgba(10,14,20,.04)
    }
    .how-num{
      position:absolute;top:-14px;left:24px;
      width:30px;height:30px;border-radius:50%;
      background:var(--cyan);color:#ffffff;
      font-weight:700;font-size:.85rem;
      display:flex;align-items:center;justify-content:center;
      box-shadow:0 4px 12px var(--cyan-glow)
    }
    .how-title{font-size:1.1rem;font-weight:700;color:var(--ink);margin:8px 0 8px;letter-spacing:-.005em}
    .how-body{font-size:.88rem;color:var(--ink-soft);line-height:1.65;margin-bottom:16px}
    .how-duration{
      display:inline-block;font-family:var(--mono);font-size:.72rem;font-weight:500;
      color:var(--green);background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.2);
      padding:4px 10px;border-radius:6px;letter-spacing:.02em
    }

    /* ── STATS — dark band for visual break (Stripe pattern) */
    .stats-band{background:var(--dark-bg);color:var(--dark-ink);padding:80px 0;position:relative;overflow:hidden}
    .stats-band::before{
      content:'';position:absolute;top:-180px;right:-180px;width:480px;height:480px;border-radius:50%;
      background:radial-gradient(circle,rgba(0,160,133,.16) 0%,transparent 70%)
    }
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative}
    .stat-item{text-align:center}
    .stat-val{
      font-size:clamp(2.4rem,4.5vw,3.4rem);font-weight:700;
      color:var(--cyan);letter-spacing:-.03em;line-height:1;margin-bottom:8px;
      font-feature-settings:'tnum'
    }
    .stat-suffix{color:var(--cyan);font-weight:600}
    .stat-label{font-size:.86rem;color:var(--dark-ink-soft);font-weight:400}

    /* ── COMPLIANCE */
    .compliance{background:var(--bg-2)}
    .compliance-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:64px;align-items:start}
    .compliance-body{font-size:1rem;color:var(--ink-soft);line-height:1.85}
    .compliance-badges{display:flex;flex-wrap:wrap;gap:10px}
    .compliance-badge{
      background:var(--surface);border:1px solid var(--line-md);border-radius:8px;
      padding:10px 16px;font-size:.86rem;font-weight:600;color:var(--ink);
      display:inline-flex;align-items:center;gap:8px;
      box-shadow:0 1px 2px rgba(10,14,20,.04)
    }
    .compliance-badge::before{content:'✓';color:var(--cyan);font-weight:700}

    /* ── PRICING */
    .pricing{background:var(--bg)}
    .pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:18px;max-width:1100px;margin:0 auto}
    .price-card{
      background:var(--surface);border:1px solid var(--line);border-radius:14px;
      padding:32px 28px;display:flex;flex-direction:column;gap:14px;position:relative;
      box-shadow:0 1px 3px rgba(10,14,20,.04)
    }
    .price-card.popular{
      border-color:var(--cyan);
      box-shadow:0 0 0 1px var(--cyan), 0 22px 60px -22px var(--cyan-glow)
    }
    .price-card.popular::before{
      content:'Most popular';position:absolute;top:-12px;right:24px;
      background:var(--cyan);color:#ffffff;font-size:.7rem;font-weight:700;
      padding:5px 12px;border-radius:100px;letter-spacing:.04em;text-transform:uppercase
    }
    .price-name{font-size:.86rem;font-weight:600;color:var(--ink-mute);letter-spacing:.06em;text-transform:uppercase}
    .price-amount{font-size:1.7rem;font-weight:700;color:var(--ink);letter-spacing:-.015em;font-feature-settings:'tnum'}
    .price-tagline{font-size:.92rem;color:var(--ink-soft);margin-bottom:6px}
    .price-features{list-style:none;display:flex;flex-direction:column;gap:10px;flex:1;margin:8px 0 18px}
    .price-features li{font-size:.9rem;color:var(--ink-soft);display:flex;gap:10px;line-height:1.55}
    .price-features li::before{content:'✓';color:var(--cyan);flex-shrink:0;font-weight:700}
    .price-cta{
      width:100%;text-align:center;padding:12px;border-radius:8px;
      font-size:.92rem;font-weight:600;letter-spacing:.005em;
      background:var(--bg-2);color:var(--ink);border:1px solid var(--line-md);
      transition:background .2s,color .2s,border-color .2s
    }
    .price-cta:hover{background:var(--ink);color:#fff;border-color:var(--ink)}
    .price-card.popular .price-cta{background:var(--cyan);color:#ffffff;border-color:var(--cyan)}
    .price-card.popular .price-cta:hover{background:#008a72;border-color:#008a72}

    /* ── CTA — dark band for contrast break (Stripe pattern) */
    .cta-band{background:var(--dark-bg);color:var(--dark-ink);padding:96px 0;text-align:center;position:relative;overflow:hidden}
    .cta-band::before{
      content:'';position:absolute;bottom:-200px;left:-150px;width:520px;height:520px;border-radius:50%;
      background:radial-gradient(circle,rgba(0,160,133,.14) 0%,transparent 70%)
    }
    .cta-band .container{position:relative}
    .cta-title{font-size:clamp(2rem,4vw,3.4rem);font-weight:700;line-height:1.1;letter-spacing:-.02em;margin-bottom:16px;color:var(--dark-ink)}
    .cta-title .accent{color:var(--cyan)}
    .cta-body{font-size:1.02rem;color:var(--dark-ink-soft);max-width:540px;margin:0 auto 28px;line-height:1.7}
    .cta-note{font-size:.78rem;color:var(--dark-ink-mute);margin-top:14px;font-family:var(--mono)}
    /* Override btn-primary inside dark CTA — needs to read against dark bg */
    .cta-band .btn-primary{background:var(--cyan);color:#ffffff;box-shadow:0 8px 22px var(--cyan-glow)}
    .cta-band .btn-primary:hover{background:#008a72;color:#fff;box-shadow:0 14px 32px rgba(0,160,133,.4)}

    /* ── FOOTER — kept dark for contrast (Stripe pattern) */
    .footer{background:var(--dark-bg);color:var(--dark-ink-mute);padding:56px 0 24px}
    .footer-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:48px;margin-bottom:36px}
    .f-brand{font-size:1.1rem;font-weight:700;color:var(--dark-ink);margin-bottom:6px}
    .f-tag{font-size:.86rem;color:var(--dark-ink-mute);max-width:280px;line-height:1.6;margin-bottom:14px}
    .f-col-title{font-size:.74rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--cyan);margin-bottom:14px}
    .f-links{list-style:none;display:flex;flex-direction:column;gap:8px}
    .f-links a,.f-links li{color:var(--dark-ink-soft);font-size:.88rem;transition:color .2s}
    .f-links a:hover{color:var(--dark-ink)}
    .footer-bottom{
      border-top:1px solid var(--dark-line);padding-top:18px;
      display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;
      font-size:.78rem;color:var(--dark-ink-mute)
    }

    /* ── RESPONSIVE */
    @media (max-width:980px){
      .hero-grid,.compliance-grid{grid-template-columns:1fr;gap:48px}
      .how-grid{grid-template-columns:repeat(2,1fr)}
      .stats-grid{grid-template-columns:repeat(2,1fr)}
      .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
    }
    @media (max-width:600px){
      .container{padding:0 22px}
      .nav-links li:not(:last-child):not(.nav-cta-li){display:none}
      .section-pad{padding:64px 0}
      .how-grid,.stats-grid{grid-template-columns:1fr}
      .footer-grid{grid-template-columns:1fr;gap:28px}
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="#" class="brand"><span class="brand-dot"></span><%= bn %></a>
      <ul class="nav-links">
        <li><a href="#products">Products</a></li>
        <li><a href="#pricing">Pricing</a></li>
        <li><a href="#compliance">Security</a></li>
        <li><a href="#cta" class="nav-cta"><%= esc(heroCtaPrimaryV) %></a></li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="reveal">
        <div class="hero-badge"><%= esc(heroBadgeV) %></div>
        <h1 class="hero-title"><%= esc(heroHeadlineLeadV) %> <span class="accent"><%= esc(heroHeadlineAccentV) %></span></h1>
        <p class="hero-sub"><%= esc(heroSubV) %></p>
        <div class="hero-actions">
          <a href="#cta" class="btn btn-primary"><%= esc(heroCtaPrimaryV) %> →</a>
          <a href="#products" class="btn btn-ghost"><%= esc(heroCtaSecondaryV) %></a>
        </div>
      </div>
      <div class="code-panel reveal">
        <div class="code-head">
          <span class="code-dot r"></span><span class="code-dot o"></span><span class="code-dot g"></span>
          <span class="code-lang"><%= esc(codeLanguageV) %></span>
        </div>
        <pre class="code-body"><%- esc(codeSnippetV)
          .replace(/\b(const|let|var|await|async|function|export|import|return|new)\b/g, '<span class="kw">$1</span>')
          .replace(/(\w+)(?=\()/g, '<span class="fn">$1</span>')
          .replace(/('[^']*'|"[^"]*"|`[^`]*`)/g, '<span class="str">$1</span>')
          .replace(/\b(\d+)\b/g, '<span class="num">$1</span>')
          .replace(/(\/\/.*$)/gm, '<span class="cm">$1</span>')
        %></pre>
      </div>
    </div>
  </section>

  <!-- LOGOS -->
  <% if (customerLogosList.length) { %>
  <section class="logos">
    <div class="logos-eyebrow">Trusted by insurers, brokers, and platforms</div>
    <div class="logos-row">
      <% customerLogosList.forEach(function(c){ %><span class="logo-name"><%= esc(c) %></span><% }); %>
    </div>
  </section>
  <% } %>

  <!-- PRODUCTS -->
  <section id="products" class="products section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow"><%= esc(productsLabelV) %></div>
        <h2 class="section-title"><%= esc(productsHeadlineV) %></h2>
        <p class="section-body"><%= esc(productsBodyV) %></p>
      </div>
      <div class="products-grid">
        <% productsList.forEach(function(p){ %>
        <article class="product-card reveal">
          <div class="product-icon"><%= esc(p.icon || '⚡') %></div>
          <h3 class="product-name"><%= esc(p.name) %></h3>
          <p class="product-body"><%= esc(p.body) %></p>
          <% if (p.endpoint) { %><span class="product-endpoint"><%= esc(p.endpoint) %></span><% } %>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" class="how section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow"><%= esc(howLabelV) %></div>
        <h2 class="section-title"><%= esc(howHeadlineV) %></h2>
      </div>
      <div class="how-grid">
        <% howStepsList.forEach(function(s, i){ %>
        <div class="how-step reveal">
          <div class="how-num"><%= String(i+1).padStart(2,'0') %></div>
          <h3 class="how-title"><%= esc(s.title) %></h3>
          <p class="how-body"><%= esc(s.body) %></p>
          <% if (s.duration) { %><span class="how-duration">⏱ <%= esc(s.duration) %></span><% } %>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats-band">
    <div class="container stats-grid">
      <% platformStatsList.forEach(function(n){ %>
      <div class="stat-item reveal">
        <div class="stat-val"><%= esc(n.value) %><span class="stat-suffix"><%= esc(n.suffix || '') %></span></div>
        <div class="stat-label"><%= esc(n.label) %></div>
      </div>
      <% }); %>
    </div>
  </section>

  <!-- COMPLIANCE -->
  <section id="compliance" class="compliance section-pad">
    <div class="container compliance-grid">
      <div class="reveal">
        <div class="section-eyebrow"><%= esc(complianceLabelV) %></div>
        <h2 class="section-title"><%= esc(complianceHeadlineV) %></h2>
        <p class="compliance-body"><%= esc(complianceBodyV) %></p>
      </div>
      <div class="compliance-badges reveal">
        <% complianceBadgesList.forEach(function(b){ %>
          <span class="compliance-badge"><%= esc(b) %></span>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="pricing section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow"><%= esc(pricingLabelV) %></div>
        <h2 class="section-title"><%= esc(pricingHeadlineV) %></h2>
      </div>
      <div class="pricing-grid">
        <% pricingPlansList.forEach(function(p){ var pop = String(p.popular).toLowerCase() === 'yes'; %>
        <article class="price-card<% if (pop) { %> popular<% } %> reveal">
          <div class="price-name"><%= esc(p.name) %></div>
          <div class="price-amount"><%= esc(p.price) %></div>
          <% if (p.tagline) { %><div class="price-tagline"><%= esc(p.tagline) %></div><% } %>
          <ul class="price-features">
            <% parseFeatures(p.features).forEach(function(f){ %>
              <li><%= esc(f) %></li>
            <% }); %>
          </ul>
          <a href="#cta" class="price-cta"><%= esc(p.cta || 'Get started') %></a>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="cta" class="cta-band">
    <div class="container reveal">
      <h2 class="cta-title"><%= esc(ctaHeadlineLeadV) %> <span class="accent"><%= esc(ctaHeadlineAccentV) %></span></h2>
      <p class="cta-body"><%= esc(ctaBodyV) %></p>
      <a href="mailto:<%= esc(emailV) %>" class="btn btn-primary"><%= esc(ctaButtonV) %> →</a>
      <% if (ctaNoteV) { %><div class="cta-note"><%= esc(ctaNoteV) %></div><% } %>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="f-brand"><%= bn %></div>
          <p class="f-tag"><%= tagln %></p>
        </div>
        <div>
          <p class="f-col-title">Product</p>
          <ul class="f-links">
            <% productsList.slice(0,5).forEach(function(p){ %><li><a href="#products"><%= esc(p.name) %></a></li><% }); %>
          </ul>
        </div>
        <div>
          <p class="f-col-title">Resources</p>
          <ul class="f-links">
            <li><a href="#how">Integration</a></li>
            <li><a href="#compliance">Security</a></li>
            <li><a href="#pricing">Pricing</a></li>
            <li><a href="#cta">Get API Keys</a></li>
          </ul>
        </div>
        <div>
          <p class="f-col-title">Contact</p>
          <ul class="f-links">
            <li><%= esc(emailV) %></li>
            <li><%= esc(phoneV) %></li>
            <li><%= esc(addressV) %></li>
            <li><%= esc(hoursV) %></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© <%= year %> <%= bn %>. All rights reserved.</span>
        <span>Privacy · Terms · Status · GitHub</span>
      </div>
    </div>
  </footer>

  <script>
    var ro = new IntersectionObserver(function(es){
      es.forEach(function(e){ if (e.isIntersecting){ e.target.classList.add('visible'); ro.unobserve(e.target); } });
    }, { threshold:.06, rootMargin:'0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(function(el){ ro.observe(el); });
    document.querySelectorAll('a[href^="#"]').forEach(function(a){
      a.addEventListener('click', function(e){
        var t = document.querySelector(a.getAttribute('href'));
        if (t){ e.preventDefault(); t.scrollIntoView({ behavior:'smooth', block:'start' }); }
      });
    });
  </script>
</body>
</html>
