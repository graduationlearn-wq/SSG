# ═══════════════════════════════════════════════════════════
# BeyondSite — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (MySQL) ─────────────────────────────────────
# Primary connection string — used by Prisma in production.
# Local dev: mysql://app_user:password@localhost:3306/beyondsite
# AWS RDS:   mysql://app_user:password@your-rds-endpoint:3306/beyondsite
DATABASE_URL=mysql://app_user:password@localhost:3306/beyondsite

# Local dev only (docker-compose spins up a MySQL container using these).
# In production on RDS, only DATABASE_URL above is needed.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=beyondsite
DB_USER=app_user
DB_PASSWORD=change-me-in-prod
DB_ROOT_PASSWORD=change-me-in-prod

# ── Uploads ───────────────────────────────────────────────
# local  = disk storage at public/uploads/images
# s3     = AWS S3 (requires AWS_* vars below)
UPLOAD_STORAGE=local

# AWS S3 (required only if UPLOAD_STORAGE=s3)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=beyondsite-uploads

# ── Auth (optional — app runs in dev-bypass mode if unset) ─
# Set AUTH0_DOMAIN and AUTH0_AUDIENCE to activate Auth0.
# Without them, all requests default to admin role (dev mode).
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# ── Payment provider ─────────────────────────────────────
# dummy    = in-memory $9 demo gateway (no real charge)
# razorpay = enable the Razorpay scaffold in src/lib/payments.js (India)
# stripe   = enable the Stripe scaffold in src/lib/payments.js (global)
PAYMENT_PROVIDER=dummy

# Razorpay (required if PAYMENT_PROVIDER=razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe (required if PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APP_URL=http://localhost:3000

# ── First-admin bootstrap (used by `npm run db:seed`) ────
# After the first deploy, this email is upserted into the
# users table with role=ADMIN so somebody can sign in via
# Auth0 and reach the admin UI.
AUTH0_BOOTSTRAP_ADMIN_EMAIL=admin@beyondsite.com

# ── AI ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# ── Logging ───────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info